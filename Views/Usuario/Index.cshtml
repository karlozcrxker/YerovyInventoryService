@model List<YerovyInventoryService.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>

    * {
        font-family: 'Poppins', sans-serif;
    }

    body {
        background-color: #050505;
    }

    .users-container {
        padding-top: 50px;
        padding-bottom: 50px;
        color: white;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .red-text {
        color: #ff2d2d;
    }

    .page-description {
        color: #bdbdbd;
        font-size: 1.05rem;
        line-height: 1.8;
        max-width: 800px;
    }

    .btn-yerovy {
        background: linear-gradient(135deg, #a80000, #ff2d2d);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-yerovy:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255,0,0,.35);
        }

    .user-card {
        background-color: #101010;
        border: 1px solid #252525;
        border-radius: 24px;
        padding: 30px;
        transition: .3s ease;
        height: 100%;
    }

        .user-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255,0,0,.3);
            box-shadow: 0 10px 25px rgba(255,0,0,.08);
        }

    .user-role {
        display: inline-block;
        background: linear-gradient(135deg, #a80000, #ff2d2d);
        color: white;
        padding: 8px 16px;
        border-radius: 999px;
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .user-name {
        color: white;
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .user-info {
        color: #c2c2c2;
        line-height: 2;
    }

        .user-info strong {
            color: white;
        }

    .user-actions {
        margin-top: 25px;
        display: flex;
        gap: 10px;
    }

    .btn-edit {
        background-color: #ffc107;
        border: none;
        color: black;
        font-weight: 600;
        border-radius: 12px;
        padding: 10px 18px;
    }

    .btn-delete {
        background-color: #dc3545;
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 12px;
        padding: 10px 18px;
    }

        .btn-edit:hover,
        .btn-delete:hover {
            transform: translateY(-2px);
        }

    .error-box {
        background-color: #101010;
        border: 1px solid rgba(255,0,0,.2);
        border-radius: 24px;
        padding: 50px;
        text-align: center;
        margin-top: 60px;
    }

        .error-box h1 {
            color: #ff2d2d;
            font-size: 4rem;
            font-weight: 800;
        }

        .error-box p {
            color: #c4c4c4;
            font-size: 1.1rem;
            margin-top: 20px;
        }

</style>

@if (Context.Session.GetString("Rol") == "Cliente")
{
    <div class="container users-container">

        <div class="error-box">
            <h1>
                ACCESO DENEGADO
            </h1>
            <p>
                No tienes los permisos necesarios para
                acceder a este módulo.
            </p>
        </div>

    </div>
}

else
{
    <div class="container users-container">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

            <div>
                <h1 class="page-title">Gestión de
                    <span class="red-text">Usuarios</span>
                </h1>

                <p class="page-description">

                    Administra los usuarios, permisos
                    y accesos dentro del sistema
                    YerovyInventoryService.

                </p>
            </div>

            @if (Context.Session.GetString("Rol") == "admin")
            {
                <a class="btn btn-yerovy" href="/Usuario/Create">
                    <i class="fa-solid fa-plus"></i>
                    Nuevo Usuario
                </a>
            }
            

        </div>

        <div class="row g-4">
            @foreach (var user in Model)
            {
                <div class="col-lg-3 col-md-6">

                    <div class="user-card">

                        <div class="user-role">@user.Rol</div>

                        <h3 class="user-name">
                            @user.Nombre
                        </h3>

                        <div class="user-info">

                            <div>
                                <strong>Correo: </strong>@user.Correo
                            </div>

                            <div>
                                <strong>Celular: </strong>@user.Celular
                            </div>

                        </div>

                        @if (Context.Session.GetString("Rol") == "admin")
                        {
                            <div class="user-actions">

                                <a href="/Usuario/Edit/@user.Id" class="btn btn-edit">
                                    <i class="fa-solid fa-pen"></i>
                                    Editar
                                </a>

                                <a href="/Usuario/Delete/@user.Id" class="btn btn-delete">
                                    <i class="fa-solid fa-trash"></i>
                                    Eliminar
                                </a>

                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}