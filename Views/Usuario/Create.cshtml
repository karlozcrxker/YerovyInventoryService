@model YerovyInventoryService.Models.Usuario

@{
    ViewData["Title"] = "Crear Usuario";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>

    * {
        font-family: 'Poppins', sans-serif;
    }

    body {
        background-color: #050505;
    }

    .create-container {
        padding-top: 50px;
        padding-bottom: 50px;
        color: white;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .red-text {
        color: #ff2d2d;
    }

    .page-description {
        color: #bdbdbd;
        line-height: 1.8;
        font-size: 1.05rem;
        max-width: 700px;
    }

    .form-card {
        background-color: #101010;
        border: 1px solid #252525;
        border-radius: 24px;
        padding: 40px;
        margin-top: 40px;
    }

    .form-label {
        color: white;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .form-control,
    .form-select {
        background-color: #121212 !important;
        border: 1px solid #2b2b2b !important;
        color: white !important;
        border-radius: 14px;
        padding: 14px 16px;
    }

        .form-control:focus,
        .form-select:focus {
            background-color: #121212 !important;
            color: white !important;
            border-color: #ff2d2d !important;
            box-shadow: 0 0 0 .2rem rgba(255,0,0,.15);
        }

    .btn-yerovy {
        background: linear-gradient(135deg, #a80000, #ff2d2d);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-yerovy:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255,0,0,.35);
        }

    .btn-back {
        background-color: #202020;
        border: 1px solid #333;
        color: white;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-back:hover {
            color: white;
            background-color: #2a2a2a;
        }

    .validation-summary-errors,
    .text-danger {
        color: #ff6b6b !important;
    }

</style>

<div class="container create-container">

    <div>
        <h1 class="page-title">
            Crear
            <span class="red-text">
                Usuario
            </span>
        </h1>

        <p class="page-description">

            Registra nuevos usuarios y asigna
            permisos dentro del sistema
            YerovyInventoryService.

        </p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-4"></div>

            <div class="mb-4">
                <label class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Correo</label>
                <input asp-for="Correo"class="form-control" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            @if (Context.Session.GetString("Rol") != null)
            {
                <div class="mb-4">
                    <label class="form-label">Rol</label>
                    <select asp-for="Rol" class="form-select">
                        <option value="Trabajador">Trabajador</option>
                        <option value="Cliente">Cliente</option>
                    </select>
                </div>
            }

            @if (Context.Session.GetString("Rol") == null){
                <div class="mb-4">
                    <label class="form-label">Rol</label>
                    <select asp-for="Rol" class="form-select">
                        <option value="Cliente">Cliente</option>
                    </select>
                </div>
            }

            <div class="mb-4">
                <label class="form-label">Celular</label>
                <input asp-for="Celular" class="form-control" />
                <span asp-validation-for="Celular" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Clave</label>
                <input asp-for="Clave" type="password" class="form-control" />
                <span asp-validation-for="Clave" class="text-danger"></span>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button class="btn btn-yerovy">
                    <i class="fa-solid fa-user-plus"></i>
                    Guardar
                </button>

                <a href="/Usuario" class="btn btn-back">
                    Volver
                </a>
            </div>

        </form>
    </div>
</div>