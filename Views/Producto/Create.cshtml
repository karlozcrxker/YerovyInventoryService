@model YerovyInventoryService.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>

    * {
        font-family: 'Poppins', sans-serif;
    }

    body {
        background-color: #050505;
    }

    .create-container {
        padding-top: 50px;
        padding-bottom: 50px;
        color: white;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .red-text {
        color: #ff2d2d;
    }

    .page-description {
        color: #bdbdbd;
        line-height: 1.8;
        font-size: 1.05rem;
        max-width: 700px;
    }

    .form-card {
        background-color: #101010;
        border: 1px solid #252525;
        border-radius: 24px;
        padding: 40px;
        margin-top: 40px;
    }

    .form-label {
        color: white;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .form-control,
    .form-select {
        background-color: #121212 !important;
        border: 1px solid #2b2b2b !important;
        color: white !important;
        border-radius: 14px;
        padding: 14px 16px;
    }

        .form-control:focus,
        .form-select:focus {
            background-color: #121212 !important;
            color: white !important;
            border-color: #ff2d2d !important;
            box-shadow: 0 0 0 .2rem rgba(255,0,0,.15);
        }

    .btn-yerovy {
        background: linear-gradient( 135deg, #a80000, #ff2d2d );
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-yerovy:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255,0,0,.35);
        }

    .btn-back {
        background-color: #202020;
        border: 1px solid #333;
        color: white;
        font-weight: 600;
        padding: 12px 22px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-back:hover {
            color: white;
            background-color: #2a2a2a;
        }

</style>

<div class="container create-container">

    <!-- TITULO -->

    <div>

        <h1 class="page-title">

            Agregar
            <span class="red-text">
                Producto o Servicio
            </span>

        </h1>

        <p class="page-description">

            Registra nuevos productos, accesorios
            o servicios dentro del sistema
            de inventario de Polarizados Yerovy.

        </p>

    </div>

    <!-- FORMULARIO -->

    <div class="form-card">

        <form asp-action="Create"
              method="post"
              enctype="multipart/form-data">

            <!-- TIPO -->

            <div class="mb-4">

                <label class="form-label">

                    Tipo

                </label>

                <select asp-for="Tipo"
                        class="form-select">

                    <option value="Producto">
                        Producto
                    </option>

                    <option value="Servicio">
                        Servicio
                    </option>

                </select>

            </div>

            <!-- NOMBRE -->

            <div class="mb-4">

                <label class="form-label">

                    Nombre

                </label>

                <input asp-for="Nombre"
                       class="form-control" />

            </div>

            <!-- PRECIO -->

            <div class="mb-4">

                <label class="form-label">

                    Precio

                </label>

                <input asp-for="Precio"
                       class="form-control" />

            </div>

            <!-- STOCK -->

            <div class="mb-4">

                <label class="form-label">

                    Stock

                </label>

                <input asp-for="Stock"
                       class="form-control" />

            </div>

            <!-- CATEGORIA -->

            <div class="mb-4">

                <label class="form-label">

                    Categoría

                </label>

                <select asp-for="CategoriaId"
                        class="form-select">

                    <option value="">
                        Seleccione una categoría
                    </option>

                    @foreach (var cat in ViewBag.Categorias)
                    {
                        <option value="@cat.Id">
                            @cat.Nombre
                        </option>
                    }

                </select>

            </div>

            <!-- IMAGEN -->

            <div class="mb-4">

                <label class="form-label">

                    Imagen

                </label>

                <input type="file"
                       name="imagen"
                       class="form-control" />

            </div>

            <!-- BOTONES -->

            <div class="d-flex gap-3 mt-4">

                <button class="btn btn-yerovy">

                    <i class="fa-solid fa-floppy-disk"></i>

                    Guardar

                </button>

                <a href="/Producto"
                       class="btn btn-back">

                    Volver

                </a>

            </div>

        </form>

    </div>

</div>