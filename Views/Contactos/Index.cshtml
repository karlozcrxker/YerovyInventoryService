@{
    ViewData["Title"] = "Contactos";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>

    * {
        font-family: 'Poppins', sans-serif;
    }

    body {
        background-color: #050505;
    }

    .contact-container {
        padding-top: 50px;
        padding-bottom: 50px;
        color: white;
    }

    .contact-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 20px;
    }

    .red-text {
        color: #ff2d2d;
    }

    .contact-description {
        color: #c4c4c4;
        font-size: 1.1rem;
        line-height: 1.9;
        max-width: 800px;
    }

    .contact-card {
        background-color: #101010;
        border: 1px solid #252525;
        border-radius: 24px;
        padding: 35px;
        transition: .3s ease;
        height: 100%;
    }

        .contact-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255,0,0,.3);
            box-shadow: 0 10px 25px rgba(255,0,0,.08);
        }

    .contact-icon {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 2rem;
        margin-bottom: 25px;
        background: linear-gradient( 135deg, #a80000, #ff2d2d );
        color: white;
    }

    .contact-card h3 {
        color: white;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .contact-card p {
        color: #bdbdbd;
        line-height: 1.8;
    }

    .contact-link {
        display: inline-block;
        margin-top: 15px;
        color: #ff4d4d;
        font-weight: 600;
        text-decoration: none;
        transition: .3s ease;
    }

        .contact-link:hover {
            color: white;
            transform: translateX(4px);
        }

    .contact-number {
        margin-top: 60px;
        background: linear-gradient( 145deg, rgba(255,0,0,.08), rgba(255,255,255,.02) );
        border: 1px solid rgba(255,0,0,.15);
        border-radius: 24px;
        padding: 40px;
        text-align: center;
    }

        .contact-number h2 {
            color: white;
            font-weight: 700;
            margin-bottom: 20px;
        }

    .phone-number {
        font-size: 2rem;
        font-weight: 700;
        color: #ff2d2d;
    }

</style>

<div class="container contact-container">

    <!-- TITULO -->

    <div class="mb-5">

        <h1 class="contact-title">

            Contáctanos en
            <span class="red-text">
                Polarizados Yerovy
            </span>

        </h1>

        <p class="contact-description">

            Puedes comunicarte con nosotros mediante nuestras
            redes sociales oficiales o directamente
            a nuestro número de atención.

        </p>

    </div>

    <!-- REDES -->

    <div class="row g-4">

        <!-- FACEBOOK -->

        <div class="col-lg-4">

            <div class="contact-card">

                <div class="contact-icon">
                    <i class="fa-brands fa-facebook-f"></i>
                </div>

                <h3>
                    Facebook
                </h3>

                <p>

                    Síguenos en Facebook para conocer
                    promociones, novedades y trabajos realizados.

                </p>

                <a href="#"
                       class="contact-link">

                    Ir a Facebook →

                </a>

            </div>

        </div>

        <!-- INSTAGRAM -->

        <div class="col-lg-4">

            <div class="contact-card">

                <div class="contact-icon">
                    <i class="fa-brands fa-instagram"></i>
                </div>

                <h3>
                    Instagram
                </h3>

                <p>

                    Observa nuestros trabajos,
                    diseños y contenido automotriz
                    en Instagram.

                </p>

                <a href="#"
                       class="contact-link">

                    Ir a Instagram →

                </a>

            </div>

        </div>

        <!-- WHATSAPP -->

        <div class="col-lg-4">

            <div class="contact-card">

                <div class="contact-icon">
                    <i class="fa-brands fa-whatsapp"></i>
                </div>

                <h3>
                    WhatsApp
                </h3>

                <p>

                    Contáctanos directamente
                    para información, cotizaciones
                    y atención personalizada.

                </p>

                <a href="https://wa.me/573156151050"
                       target="_blank"
                       class="contact-link">

                    Abrir WhatsApp →

                </a>

            </div>

        </div>

    </div>

    <!-- NUMERO -->

    <div class="contact-number">

        <h2>
            Número de contacto
        </h2>

        <div class="phone-number">

            +57 315 615 1050

        </div>

    </div>

</div>