@{
    ViewData["Title"] = "Inicio";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">

<style>

    body {
        background-color: #050505;
        font-family: 'Poppins', sans-serif;
    }

    .home-container {
        color: white;
        padding-top: 50px;
        padding-bottom: 50px;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .red-text {
        color: #ff2d2d;
    }

    .hero-description {
        color: #c4c4c4;
        font-size: 1.1rem;
        line-height: 1.9;
    }

    .hero-box {
        background: linear-gradient( 145deg, rgba(255,0,0,.08), rgba(255,255,255,.02) );
        border: 1px solid rgba(255,0,0,.15);
        border-radius: 24px;
        min-height: 380px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: #d0d0d0;
        padding: 30px;
    }

    .hero-icon {
        font-size: 4rem;
        color: #ff2d2d;
        margin-bottom: 20px;
    }

    .yerovy-card {
        background-color: #101010;
        border: 1px solid #252525;
        border-radius: 20px;
        padding: 30px;
        height: 100%;
        transition: .3s ease;
    }

        .yerovy-card:hover {
            transform: translateY(-4px);
            border-color: rgba(255,0,0,.3);
            box-shadow: 0 10px 25px rgba(255,0,0,.08);
        }

        .yerovy-card h3 {
            color: white;
            margin-bottom: 20px;
        }

        .yerovy-card p {
            color: #c4c4c4;
            line-height: 1.8;
        }

    .btn-yerovy {
        background: linear-gradient( 135deg, #a80000, #ff2d2d );
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 14px;
        transition: .3s ease;
    }

        .btn-yerovy:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255,0,0,.35);
        }

    .section-title {
        color: white;
        font-weight: 700;
    }

</style>

<div class="container home-container">

    <!-- HERO -->

    <div class="row align-items-center g-5">

        <!-- TEXTO -->

        <div class="col-lg-6">
            <h1 class="hero-title">

                Bienvenido a

                <span class="red-text">
                    Polarizados Yerovy
                </span>
            </h1>

            <p class="hero-description mt-4">

                Especialistas en polarizados automotrices,
                instalación de vinilos, accesorios y
                personalización estética para vehículos y residencias.

            </p>

            <p class="hero-description">

                Esta plataforma permitirá administrar
                información del establecimiento
                de forma organizada y eficiente.

            </p>

            <div class="mt-4">
                <a asp-controller="Producto"
                       asp-action="Index"
                       class="btn btn-yerovy">

                    Explorar sistema

                </a>
            </div>
        </div>

        <!-- ESPACIO MULTIMEDIA -->

        <div class="col-lg-6">
            <div class="hero-box p-0 overflow-hidden">

                <img src="@Url.Content("~/images/FrenteLocal.jpeg")"
                     alt="Polarizados Yerovy"
                     style="
                width:100%;
                height:100%;
                object-fit:cover;
                border-radius:24px;" />
            </div>
        </div>

        <div class="hero-box p-0 overflow-hidden">
            <video controls
                   autoplay
                   muted
                   loop
                   playsinline
                   style="
                width:100%;
                height:100%;
                object-fit:cover;">

                <source src="@Url.Content("~/videos/VideoLocal.mp4")"
                        type="video/mp4">
            </video>
        </div>
    </div>

    <!-- INFORMACION -->

    <div class="row mt-5 g-4">

        <div class="col-lg-4">

            <div class="yerovy-card">

                <h3>
                    ¿Quiénes somos?
                </h3>

                <p>

                    Polarizados Yerovy es un establecimiento
                    enfocado en mejorar la estética y comodidad
                    de los vehículos mediante servicios
                    especializados.

                </p>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="yerovy-card">

                <h3>
                    Nuestro objetivo
                </h3>

                <p>

                    Ofrecer servicios de calidad mientras
                    se implementan herramientas digitales
                    modernas para optimizar el trabajo diario.

                </p>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="yerovy-card">

                <h3>
                    Plataforma moderna
                </h3>

                <p>

                    Este sistema continuará evolucionando
                    para incluir nuevas funcionalidades,
                    estadísticas y herramientas administrativas.

                </p>

            </div>

        </div>

    </div>

</div>