@{
    ViewData["Title"] = "Inicio";
}

<!DOCTYPE html>
<html>
<head>
    <title>Inicio - Sistema</title>

    <style>
            body {
                background-color: #0d0d0d;
                color: #ffffff;
                font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
                margin: 0;
            }

            .header {
                background-color: #111;
                padding: 5px;
                text-align: center;
                border-bottom: 1px solid #222;
                width: 100%;
            }

            .header h1 {
                margin: 0;
                font-size: 28px;
            }

            .container {
                display: flex;
                justify-content: center;
                gap: 30px;
                margin-top: 60px;
                flex-wrap: wrap;
            }

            .card {
                background-color: #1a1a1a;
                padding: 30px;
                border-radius: 200px;
                width: 250px;
                text-align: center;
                box-shadow: 0 0 10px rgba(0,0,0,0.5);
                transition: 0.3s;
            }

            .card:hover {
                transform: scale(1.05);
                background-color: #222;
            }

            .card h3 {
                margin-bottom: 15px;
                color: white;
            }

            .card p {
                font-size: 14px;
                color: #ccc;
            }

            .btn {
                display: inline-block;
                margin-top: 15px;
                padding: 10px 15px;
                background-color: #333;
                color: white;
                text-decoration: none;
                border-radius: 75px;
                transition: 0.3s;
            }

            .btn:hover {
                background-color: #555;
            }

    </style>
</head>

<body>
    <div class="header">
        <h1>Panel Principal</h1>
        <p>Sistema de Inventario - YerovyInventoryService</p>
    </div>
</body>
</html>